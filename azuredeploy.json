{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Complete Teams AI Agent with RAG capabilities using SharePoint data",
    "author": "ISV Solution Package"
  },
  "parameters": {
    "resourceBaseName": {
      "type": "string",
      "minLength": 4,
      "maxLength": 20,
      "metadata": {
        "description": "Used to generate names for all resources in this template"
      }
    },
    "deploymentPackageUrl": {
      "type": "securestring",
      "metadata": {
        "description": "URL to the deployment package zip file (with SAS token if using Azure Storage)"
      }
    },
    "botDisplayName": {
      "type": "string",
      "maxLength": 42,
      "metadata": {
        "description": "Display name for the bot in Teams"
      }
    },
    "location": {
      "type": "string",
      "allowedValues": [
        "eastus",
        "eastus2", 
        "westus2",
        "westeurope",
        "northeurope",
        "canadacentral",
        "australiaeast",
        "japaneast",
        "uksouth",
        "francecentral",
        "switzerlandnorth",
        "swedencentral"
      ],
      "metadata": {
        "description": "Location for all resources. Must be a region that supports both Azure OpenAI and Azure AI Search services."
      }
    },
    "webAppSKU": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": ["B1", "B2", "S1", "S2", "P1v2", "P2v2"],
      "metadata": {
        "description": "SKU for the App Service Plan"
      }
    },
    "azureOpenAIModelDeploymentName": {
      "type": "string",
      "defaultValue": "gpt-4o",
      "metadata": {
        "description": "Name for the Azure OpenAI GPT model deployment"
      }
    },
    "azureOpenAIEmbeddingDeploymentName": {
      "type": "string",
      "defaultValue": "text-embedding-3-small",
      "metadata": {
        "description": "Name for the Azure OpenAI embedding model deployment"
      }
    },
    "azureOpenAIModelName": {
      "type": "string",
      "defaultValue": "gpt-4o",
      "allowedValues": ["gpt-4o", "gpt-4", "gpt-4-turbo", "gpt-35-turbo"],
      "metadata": {
        "description": "Azure OpenAI GPT model name - latest stable models"
      }
    },
    "azureOpenAIEmbeddingModelName": {
      "type": "string",
      "defaultValue": "text-embedding-3-small",
      "metadata": {
        "description": "Azure OpenAI embedding model name"
      }
    },
    "azureOpenAIModelVersion": {
      "type": "string",
      "defaultValue": "2024-11-20",
      "allowedValues": [
        "2024-11-20"
      ],
      "metadata": {
        "description": "Azure OpenAI GPT model version - current supported versions"
      }
    },
    "azureOpenAIEmbeddingModelVersion": {
      "type": "string",
      "defaultValue": "1",
      "metadata": {
        "description": "Azure OpenAI embedding model version"
      }
    },
    "azureSearchSKU": {
      "type": "string",
      "defaultValue": "basic",
      "allowedValues": ["free", "basic", "standard", "standard2", "standard3"],
      "metadata": {
        "description": "SKU for the Azure AI Search service"
      }
    },
    "sharePointSiteUrl": {
      "type": "string",
      "metadata": {
        "description": "SharePoint site URL (e.g., https://yourtenant.sharepoint.com/sites/yoursite)"
      }
    },
    "sharePointClientId": {
      "type": "string",
      "metadata": {
        "description": "Client ID of the Azure AD App Registration for SharePoint access"
      }
    },
    "sharePointClientSecret": {
      "type": "securestring",
      "metadata": {
        "description": "Client Secret of the Azure AD App Registration for SharePoint access"
      }
    },
    "azureTenantId": {
      "type": "string",
      "metadata": {
        "description": "Azure AD Tenant ID for SharePoint authentication"
      }
    },
    "sharePointListName": {
      "type": "string",
      "defaultValue": "Documents",
      "metadata": {
        "description": "SharePoint document library/list name to index (optional, defaults to Documents)"
      }
    }
  },
  "variables": {
    "azureOpenAIResourceName": "[concat(parameters('resourceBaseName'), '-openai')]",
    "azureSearchServiceName": "[concat(parameters('resourceBaseName'), '-search')]",
    "serverfarmsName": "[parameters('resourceBaseName')]",
    "webAppName": "[parameters('resourceBaseName')]",
    "identityName": "[parameters('resourceBaseName')]",
    "searchIndexName": "sharepoint-documents"
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[variables('identityName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('azureOpenAIResourceName')]",
      "location": "[parameters('location')]",
      "kind": "OpenAI",
      "sku": {
        "name": "S0"
      },
      "properties": {
        "apiProperties": {
          "statisticsEnabled": false
        },
        "customSubDomainName": "[toLower(variables('azureOpenAIResourceName'))]"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('azureOpenAIResourceName'), '/', parameters('azureOpenAIModelDeploymentName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('azureOpenAIResourceName'))]"
      ],
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('azureOpenAIModelName')]",
          "version": "[parameters('azureOpenAIModelVersion')]"
        }
      },
      "sku": {
        "name": "Standard",
        "capacity": 15
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('azureOpenAIResourceName'), '/', parameters('azureOpenAIEmbeddingDeploymentName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('azureOpenAIResourceName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('azureOpenAIResourceName'), parameters('azureOpenAIModelDeploymentName'))]"
      ],
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('azureOpenAIEmbeddingModelName')]",
          "version": "[parameters('azureOpenAIEmbeddingModelVersion')]"
        }
      },
      "sku": {
        "name": "Standard",
        "capacity": 3
      }
    },
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2023-11-01",
      "name": "[variables('azureSearchServiceName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('azureSearchSKU')]"
      },
      "properties": {
        "replicaCount": 1,
        "partitionCount": 1,
        "hostingMode": "default",
        "publicNetworkAccess": "enabled",
        "networkRuleSet": {
          "ipRules": []
        },
        "disableLocalAuth": false,
        "authOptions": {
          "apiKeyOnly": {}
        },
        "semanticSearch": "[if(equals(parameters('azureSearchSKU'), 'basic'), null(), 'free')]"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2021-02-01",
      "name": "[variables('serverfarmsName')]",
      "location": "[parameters('location')]",
      "kind": "app",
      "sku": {
        "name": "[parameters('webAppSKU')]"
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2021-02-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('serverfarmsName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('azureOpenAIResourceName'))]",
        "[resourceId('Microsoft.Search/searchServices', variables('azureSearchServiceName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('azureOpenAIResourceName'), parameters('azureOpenAIModelDeploymentName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('azureOpenAIResourceName'), parameters('azureOpenAIEmbeddingDeploymentName'))]"
      ],
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))]": {}
        }
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('serverfarmsName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "alwaysOn": true,
          "appSettings": [
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "[parameters('deploymentPackageUrl')]"
            },
            {
              "name": "WEBSITE_NODE_DEFAULT_VERSION",
              "value": "~22"
            },
            {
              "name": "RUNNING_ON_AZURE",
              "value": "1"
            },
            {
              "name": "clientId",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))).clientId]"
            },
            {
              "name": "tenantId",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))).tenantId]"
            },
            {
              "name": "AZURE_OPENAI_API_KEY",
              "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('azureOpenAIResourceName')), '2023-05-01').key1]"
            },
            {
              "name": "AZURE_OPENAI_ENDPOINT",
              "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('azureOpenAIResourceName'))).endpoint]"
            },
            {
              "name": "AZURE_OPENAI_DEPLOYMENT_NAME",
              "value": "[parameters('azureOpenAIModelDeploymentName')]"
            },
            {
              "name": "AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME",
              "value": "[parameters('azureOpenAIEmbeddingDeploymentName')]"
            },
            {
              "name": "AZURE_SEARCH_ENDPOINT",
              "value": "[concat('https://', variables('azureSearchServiceName'), '.search.windows.net')]"
            },
            {
              "name": "AZURE_SEARCH_KEY",
              "value": "[listAdminKeys(resourceId('Microsoft.Search/searchServices', variables('azureSearchServiceName')), '2023-11-01').primaryKey]"
            },
            {
              "name": "AZURE_SEARCH_INDEX_NAME",
              "value": "[variables('searchIndexName')]"
            },
            {
              "name": "SHAREPOINT_SITE_URL",
              "value": "[parameters('sharePointSiteUrl')]"
            },
            {
              "name": "SHAREPOINT_CLIENT_ID",
              "value": "[parameters('sharePointClientId')]"
            },
            {
              "name": "SHAREPOINT_CLIENT_SECRET",
              "value": "[parameters('sharePointClientSecret')]"
            },
            {
              "name": "AZURE_TENANT_ID",
              "value": "[parameters('azureTenantId')]"
            },
            {
              "name": "SHAREPOINT_LIST_NAME",
              "value": "[parameters('sharePointListName')]"
            }
          ],
          "ftpsState": "FtpsOnly"
        }
      }
    },
    {
      "type": "Microsoft.BotService/botServices",
      "apiVersion": "2022-09-15",
      "name": "[parameters('resourceBaseName')]",
      "location": "global",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))]"
      ],
      "kind": "azurebot",
      "sku": {
        "name": "F0"
      },
      "properties": {
        "displayName": "[parameters('botDisplayName')]",
        "iconUrl": "https://docs.botframework.com/static/devportal/client/images/bot-framework-default.png",
        "endpoint": "[concat('https://', reference(resourceId('Microsoft.Web/sites', variables('webAppName'))).defaultHostName, '/api/messages')]",
        "msaAppType": "UserAssignedMSI",
        "msaAppId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))).clientId]",
        "msaAppMSIResourceId": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))]",
        "msaAppTenantId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))).tenantId]",
        "publishingCredentials": null,
        "storageResourceId": null
      }
    },
    {
      "type": "Microsoft.BotService/botServices/channels",
      "apiVersion": "2022-09-15",
      "name": "[concat(parameters('resourceBaseName'), '/MsTeamsChannel')]",
      "location": "global",
      "dependsOn": [
        "[resourceId('Microsoft.BotService/botServices', parameters('resourceBaseName'))]"
      ],
      "properties": {
        "channelName": "MsTeamsChannel",
        "properties": {
          "isEnabled": true
        }
      }
    }
  ],
  "outputs": {
    "botId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))).clientId]"
    },
    "botDomain": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('webAppName'))).defaultHostName]"
    },
    "botTenantId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))).tenantId]"
    },
    "azureOpenAIEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('azureOpenAIResourceName'))).endpoint]"
    },
    "azureOpenAIResourceName": {
      "type": "string",
      "value": "[variables('azureOpenAIResourceName')]"
    },
    "azureOpenAIDeploymentName": {
      "type": "string",
      "value": "[parameters('azureOpenAIModelDeploymentName')]"
    },
    "azureOpenAIEmbeddingDeploymentName": {
      "type": "string",
      "value": "[parameters('azureOpenAIEmbeddingDeploymentName')]"
    },
    "azureSearchEndpoint": {
      "type": "string",
      "value": "[concat('https://', variables('azureSearchServiceName'), '.search.windows.net')]"
    },
    "azureSearchServiceName": {
      "type": "string",
      "value": "[variables('azureSearchServiceName')]"
    },
    "azureSearchIndexName": {
      "type": "string",
      "value": "[variables('searchIndexName')]"
    },
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "subscriptionId": {
      "type": "string",
      "value": "[subscription().subscriptionId]"
    },
    "webAppResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/sites', variables('webAppName'))]"
    }
  }
}
